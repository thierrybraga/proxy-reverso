###############################################################################
# proxy-reverso — variáveis de ambiente
# Copie para ".env" e ajuste:  cp .env.example .env
# NUNCA comite o .env (já está no .gitignore).
###############################################################################

# ── Geral ────────────────────────────────────────────────────────────────
# Fuso horário do container (configuração de data e hora)
TZ=America/Sao_Paulo

# Seu domínio raiz (hospedado na GoDaddy)
DOMAIN=meudominio.com.br
# E-mail usado no registro do Let's Encrypt
ACME_EMAIL=voce@meudominio.com.br

# ── Portas no host (WSL) ──────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Limites de recurso do NGINX ───────────────────────────────────────────
NGINX_CPUS=1.0            # núcleos de CPU (0.5 = meio núcleo, 2.0 = dois)
NGINX_MEM_LIMIT=256m      # teto rígido de RAM
NGINX_MEM_RESERVATION=128m

# ── Nomes de container / rede (opcional) ──────────────────────────────────
NGINX_CONTAINER_NAME=lab-nginx
ACME_CONTAINER_NAME=lab-acme
CLOUDFLARED_CONTAINER_NAME=lab-cloudflared
NGROK_CONTAINER_NAME=lab-ngrok
CADVISOR_CONTAINER_NAME=lab-cadvisor
LAB_NETWORK=labnet
CADVISOR_PORT=8080

# ── Let's Encrypt via GoDaddy (DNS-01) ────────────────────────────────────
# Gere a chave/secret em: https://developer.godaddy.com/keys (ambiente "Production")
GD_KEY=
GD_SECRET=

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────
# Token do túnel criado em https://one.dash.cloudflare.com (Networks > Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=

# ── ngrok ─────────────────────────────────────────────────────────────────
# Token em https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
